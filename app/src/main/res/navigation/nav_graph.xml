<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ========================= AUTH ========================= -->

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.jobnet.app.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_loginFragment_to_recruiterDashboardFragment"
            app:destination="@id/recruiterDashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.jobnet.app.ui.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popEnterAnim="@anim/slide_in_right"
            app:popExitAnim="@anim/slide_out_left" />
    </fragment>

    <!-- ========================= JOB SEEKER ========================= -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.jobnet.app.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_jobDetails"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_notificationsFragment"
            app:destination="@id/notificationsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_categoriesFragment"
            app:destination="@id/categoriesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_categoryJobsFragment"
            app:destination="@id/categoryJobsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.jobnet.app.ui.search.SearchFragment"
        android:label="Search">
        <action
            android:id="@+id/action_search_to_jobDetails"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/savedFragment"
        android:name="com.jobnet.app.ui.saved.SavedJobsFragment"
        android:label="Saved">
        <action
            android:id="@+id/action_saved_to_jobDetails"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.jobnet.app.ui.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_profileFragment_to_searchFragment"
            app:destination="@id/searchFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_profileFragment_to_applicationsFragment"
            app:destination="@id/applicationsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_profileFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_profileFragment_to_profileSettingsFragment"
            app:destination="@id/profileSettingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popEnterAnim="@anim/slide_in_right"
            app:popExitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.jobnet.app.ui.profile.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/recruiterEditProfileFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterEditProfileFragment"
        android:label="Recruiter Edit Profile" />

    <fragment
        android:id="@+id/applicationsFragment"
        android:name="com.jobnet.app.ui.applications.ApplicationsFragment"
        android:label="My Applications">
        <action
            android:id="@+id/action_applicationsFragment_to_jobDetailsFragment"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_applicationsFragment_to_applicationTimelineFragment"
            app:destination="@id/applicationTimelineFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/applicationTimelineFragment"
        android:name="com.jobnet.app.ui.applications.ApplicationTimelineFragment"
        android:label="Application Timeline" />

    <fragment
        android:id="@+id/jobDetailsFragment"
        android:name="com.jobnet.app.ui.jobdetails.JobDetailsFragment"
        android:label="Job Detail" />

    <fragment
        android:id="@+id/categoriesFragment"
        android:name="com.jobnet.app.ui.categories.CategoriesFragment"
        android:label="Categories">
        <action
            android:id="@+id/action_categoriesFragment_to_categoryJobsFragment"
            app:destination="@id/categoryJobsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/categoryJobsFragment"
        android:name="com.jobnet.app.ui.categories.CategoryJobsFragment"
        android:label="Category Jobs">
        <action
            android:id="@+id/action_categoryJobsFragment_to_jobDetailsFragment"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/profileSettingsFragment"
        android:name="com.jobnet.app.ui.profile.ProfileSettingsFragment"
        android:label="Settings" />

    <!-- ========================= RECRUITER ========================= -->

    <fragment
        android:id="@+id/recruiterDashboardFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterDashboardFragment"
        android:label="Recruiter Dashboard">
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_recruiterPostJobFragment"
            app:destination="@id/recruiterPostJobFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_jobDetailsFragment"
            app:destination="@id/jobDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_recruiterApplicantsFragment"
            app:destination="@id/recruiterApplicantsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_recruiterEditJobFragment"
            app:destination="@id/recruiterEditJobFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterDashboardFragment_to_recruiterAllJobsFragment"
            app:destination="@id/recruiterAllJobsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/recruiterAllJobsFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterAllJobsFragment"
        android:label="Recruiter Jobs" />

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.jobnet.app.ui.notifications.NotificationsFragment"
        android:label="Notifications" />

    <fragment
        android:id="@+id/recruiterPostJobFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterPostJobFragment"
        android:label="Post Job" />

    <fragment
        android:id="@+id/recruiterApplicantsFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterApplicantsFragment"
        android:label="Applicants">
        <argument
            android:name="jobId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="jobTitle"
            app:argType="string"
            android:defaultValue="Job" />
    </fragment>

    <fragment
        android:id="@+id/recruiterEditJobFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterEditJobFragment"
        android:label="Edit Job" />

    <fragment
        android:id="@+id/recruiterProfileFragment"
        android:name="com.jobnet.app.ui.recruiter.RecruiterProfileFragment"
        android:label="Recruiter Profile">
        <action
            android:id="@+id/action_recruiterProfileFragment_to_recruiterEditProfileFragment"
            app:destination="@id/recruiterEditProfileFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterProfileFragment_to_recruiterPostJobFragment"
            app:destination="@id/recruiterPostJobFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_recruiterProfileFragment_to_recruiterDashboardFragment"
            app:destination="@id/recruiterDashboardFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

</navigation>
