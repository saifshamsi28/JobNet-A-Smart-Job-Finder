<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar_applicants"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingLeft="8dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back_applicants"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="4dp">

            <TextView
                android:id="@+id/tv_applicants_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applicants"
                android:textSize="17sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_applicants_job_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_applicants_count_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_tag_primary"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/content_applicants"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="65dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/row_applicants_filter_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_applicants_all"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:text="All"
                    android:gravity="center"
                    android:textColor="@color/text_chip_selected"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_applicants_applied"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:text="Applied"
                    android:gravity="center"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_applicants_shortlisted"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:text="Shortlisted"
                    android:gravity="center"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_applicants_rejected"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:text="Rejected"
                    android:gravity="center"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress_applicants"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="48dp"
            android:visibility="gone" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layout_empty_applicants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="72dp"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_users"
                android:contentDescription="No applicants"
                app:tint="@color/text_tertiary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No applicants yet"
                android:textSize="16sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applicants will appear here once candidates apply to this job."
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Error state -->
        <LinearLayout
            android:id="@+id/layout_error_applicants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="72dp"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_applicants_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Could not load applicants"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/error"
                android:gravity="center" />

            <TextView
                android:id="@+id/btn_retry_applicants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/primary"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Applicants list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_applicants"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
