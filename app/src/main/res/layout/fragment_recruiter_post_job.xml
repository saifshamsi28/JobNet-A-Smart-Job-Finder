<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar with back + title -->
            <LinearLayout
                android:id="@+id/post_job_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="52dp"
                android:paddingBottom="36dp">

                <!-- Back row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/btn_back_post_job"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_back"
                        android:contentDescription="Back"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="@color/text_on_dark" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Post New Job"
                        android:textColor="@color/text_on_dark"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/create_job_title"
                    android:textColor="@color/text_on_dark"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/create_job_subtitle"
                    android:textColor="@color/text_on_dark_70"
                    android:textSize="@dimen/text_base"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:background="@drawable/bg_card_white"
                android:layout_marginLeft="@dimen/page_margin"
                android:layout_marginRight="@dimen/page_margin"
                android:padding="24dp">

                <!-- Job Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/job_title_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_job_title"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="e.g. Senior Android Developer"
                    android:inputType="textCapWords|text"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Company -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/company_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_job_company"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="e.g. TechCorp Inc."
                    android:inputType="textCapWords|text"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Location + Job Type row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_job_location"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="e.g. Remote"
                            android:inputType="textCapWords|text"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salary Range"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_job_salary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="@string/salary_label"
                            android:inputType="text"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Employment Type + Work Mode row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Employment Type"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            app:endIconMode="dropdown_menu">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/input_job_employment_type"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_auth_input"
                                android:hint="Full Time"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true"
                                android:paddingLeft="16dp"
                                android:paddingRight="16dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint"
                                android:textSize="@dimen/text_md" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Work Mode"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            app:endIconMode="dropdown_menu">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/input_job_work_mode"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_auth_input"
                                android:hint="On-site"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true"
                                android:paddingLeft="16dp"
                                android:paddingRight="16dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint"
                                android:textSize="@dimen/text_md" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Category + Openings row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            app:endIconMode="dropdown_menu">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/input_job_category"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_auth_input"
                                android:hint="Engineering"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true"
                                android:paddingLeft="16dp"
                                android:paddingRight="16dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint"
                                android:textSize="@dimen/text_md" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Openings"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_job_openings"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_auth_input"
                            android:hint="e.g. 3"
                            android:inputType="number"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Required skills -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Required Skills"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_job_required_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="e.g. Java, Spring Boot, REST API"
                    android:inputType="textMultiLine|textCapWords"
                    android:minLines="2"
                    android:gravity="top"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Short Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/short_description_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_job_short_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="Brief summary of the role..."
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:gravity="top"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Full Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/full_description_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_job_full_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="Full role description, responsibilities, requirements..."
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="6"
                    android:gravity="top"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

            </LinearLayout>

            <!-- Spacer between card and button -->
            <View android:layout_width="match_parent" android:layout_height="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_draft"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginLeft="@dimen/page_margin"
                android:layout_marginRight="@dimen/page_margin"
                android:layout_marginBottom="10dp"
                android:text="@string/save_draft"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_md"
                app:backgroundTint="@color/transparent"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="@color/primary"
                app:iconPadding="8dp" />

            <!-- Publish button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_publish_job"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginLeft="@dimen/page_margin"
                android:layout_marginRight="@dimen/page_margin"
                android:background="@drawable/bg_button_primary"
                android:text="@string/create_job_action"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textSize="@dimen/text_lg"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_upload"
                app:iconTint="@color/text_on_primary"
                app:iconSize="20dp"
                app:iconPadding="8dp" />

            <ProgressBar
                android:id="@+id/publish_job_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
