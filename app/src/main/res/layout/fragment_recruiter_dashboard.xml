<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO HEADER -->
            <LinearLayout
                android:id="@+id/recruiter_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="52dp"
                android:paddingBottom="40dp">

                <!-- Top bar: Greeting + Bell + Avatar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_recruiter_greeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good Morning,"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif"
                            android:letterSpacing="0.03" />

                        <TextView
                            android:id="@+id/tv_recruiter_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Recruiter"
                            android:textColor="@color/text_on_dark"
                            android:textSize="@dimen/text_2xl"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="-0.01" />

                        <!-- Role badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="RECRUITER"
                            android:textColor="@color/primary_light"
                            android:textSize="@dimen/text_xs"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.12"
                            android:background="@color/overlay_white_10"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />
                    </LinearLayout>

                    <!-- Bell + Avatar -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:id="@+id/btn_notification"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="12dp"
                            android:background="@color/overlay_white_20"
                            android:backgroundTint="@color/overlay_white_20"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">
                            <ImageView
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bell"
                                android:contentDescription="Notifications"
                                app:tint="@color/text_on_dark" />
                            <TextView
                                android:id="@+id/view_notification_badge_dot"
                                android:layout_width="wrap_content"
                                android:layout_height="18dp"
                                android:minWidth="18dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/bg_badge_count"
                                android:gravity="center"
                                android:paddingLeft="4dp"
                                android:paddingRight="4dp"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:fontFamily="@font/inter_semibold"
                                android:visibility="gone" />
                        </FrameLayout>

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_recruiter_avatar"
                            android:layout_width="@dimen/avatar_sm"
                            android:layout_height="@dimen/avatar_sm"
                            android:contentDescription="Profile"
                            android:src="@drawable/ic_person"
                            app:civ_border_width="2.5dp"
                            app:civ_border_color="@color/primary_light"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Stats bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@color/overlay_white_10"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_stat_total_jobs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_on_dark"
                            android:textSize="@dimen/text_3xl"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Jobs"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="@dimen/text_xs"
                            android:letterSpacing="0.03" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/overlay_white_20" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_stat_active_jobs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/success"
                            android:textSize="@dimen/text_3xl"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="@dimen/text_xs"
                            android:letterSpacing="0.03" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/overlay_white_20" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_stat_applicants"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_on_dark"
                            android:textSize="@dimen/text_3xl"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Applicants"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="@dimen/text_xs"
                            android:letterSpacing="0.03" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- POST JOB BUTTON (overlapping card) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="@dimen/space_20"
                android:paddingBottom="@dimen/space_8">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_job"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/post_new_job"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_lg"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_edit"
                    app:iconTint="@color/text_on_primary"
                    app:iconSize="20dp"
                    app:iconPadding="8dp" />
            </LinearLayout>

            <!-- SECTION: Your Posted Jobs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="@dimen/space_16"
                android:paddingBottom="@dimen/space_12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Your Posted Jobs"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_recruiter_all_jobs"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="48dp"
                    android:gravity="center"
                    android:text="All"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="@dimen/space_8"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/row_dashboard_status_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_dashboard_active"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Active (0)"
                        android:textColor="@color/text_chip_selected"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:id="@+id/chip_dashboard_closed"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Closed (0)"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:id="@+id/chip_dashboard_draft"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Draft (0)"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/recruiter_jobs_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/tv_recruiter_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="40dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_primary"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_briefcase"
                        android:contentDescription="No jobs"
                        app:tint="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No jobs posted yet"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_recruiter_jobs"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_base"
                    android:gravity="center"
                    android:paddingHorizontal="32dp" />
            </LinearLayout>

            <!-- Jobs RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recruiter_jobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="@dimen/space_16"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view_dashboard_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="100dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingTop="52dp"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/skel_dash_greeting"
                            android:layout_width="110dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_skeleton_rect_round" />

                        <View
                            android:id="@+id/skel_dash_name"
                            android:layout_width="150dp"
                            android:layout_height="24dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_skeleton_rect_round" />

                        <View
                            android:id="@+id/skel_dash_role"
                            android:layout_width="90dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_skeleton_rect_round" />
                    </LinearLayout>

                    <View
                        android:id="@+id/skel_dash_bell"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_skeleton_circle" />

                    <View
                        android:id="@+id/skel_dash_avatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_skeleton_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/overlay_white_10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <View
                        android:id="@+id/skel_dash_stat_1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_skeleton_rect" />

                    <View
                        android:id="@+id/skel_dash_stat_2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"
                        android:background="@drawable/bg_skeleton_rect" />

                    <View
                        android:id="@+id/skel_dash_stat_3"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_skeleton_rect" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingTop="@dimen/space_20"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="@dimen/space_8">

                <View
                    android:id="@+id/skel_dash_cta"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:background="@drawable/bg_skeleton_rect" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/page_margin"
                android:paddingTop="@dimen/space_16"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="@dimen/space_12">

                <View
                    android:id="@+id/skel_dash_jobs_title"
                    android:layout_width="150dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_skeleton_rect_round" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <View
                    android:id="@+id/skel_dash_jobs_all"
                    android:layout_width="30dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_rect_round" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="@dimen/space_10">

                <View
                    android:id="@+id/skel_dash_chip_1"
                    android:layout_width="88dp"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skeleton_rect_round" />

                <View
                    android:id="@+id/skel_dash_chip_2"
                    android:layout_width="88dp"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skeleton_rect_round" />

                <View
                    android:id="@+id/skel_dash_chip_3"
                    android:layout_width="88dp"
                    android:layout_height="@dimen/chip_height"
                    android:background="@drawable/bg_skeleton_rect_round" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/skel_dash_job_card_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin">

                <include layout="@layout/item_recruiter_job_skeleton" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/skel_dash_job_card_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin">

                <include layout="@layout/item_recruiter_job_skeleton" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
