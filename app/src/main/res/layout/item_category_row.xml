<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="18dp"
    android:paddingTop="16dp"
    android:paddingRight="18dp"
    android:paddingBottom="16dp"
    android:background="@color/surface"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:background="@drawable/bg_icon_primary"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/iv_row_category_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_briefcase"
            android:contentDescription="Category icon"
            android:tint="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_row_category_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Engineering"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/inter_semibold" />

        <TextView
            android:id="@+id/tv_row_category_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="120 openings"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular" />
    </LinearLayout>

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_arrow_right"
        android:tint="@color/text_hint"
        android:contentDescription="Open category" />

</LinearLayout>
