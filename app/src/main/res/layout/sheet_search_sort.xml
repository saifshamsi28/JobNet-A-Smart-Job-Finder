<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_sort_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="20dp"
    android:paddingTop="14dp"
    android:paddingRight="20dp"
    android:paddingBottom="20dp"
    android:background="@color/bg_surface">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort Jobs"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="@font/inter_semibold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:text="Choose how results should be ordered"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/inter_regular" />

    <LinearLayout
        android:id="@+id/option_sort_relevance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_sort_option"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Relevance"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <ImageView
            android:id="@+id/iv_sort_selected_relevance"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/primary"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_sort_newest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_sort_option"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_clock"
            android:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Newest"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <ImageView
            android:id="@+id/iv_sort_selected_newest"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/primary"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_sort_salary_high"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_sort_option"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_dollar"
            android:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Salary: High to Low"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <ImageView
            android:id="@+id/iv_sort_selected_salary_high"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/primary"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_sort_salary_low"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_sort_option"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_dollar"
            android:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Salary: Low to High"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <ImageView
            android:id="@+id/iv_sort_selected_salary_low"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/primary"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/option_sort_company"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_sort_option"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_briefcase"
            android:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Company: A to Z"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <ImageView
            android:id="@+id/iv_sort_selected_company"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/primary"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
