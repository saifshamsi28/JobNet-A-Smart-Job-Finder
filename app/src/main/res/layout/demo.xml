<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- Dark header -->
    <LinearLayout
        android:id="@+id/recruiter_profile_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_dark_header"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp">

        <!-- Top row: title + settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Profile"
                android:textSize="18sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_on_dark" />

            <ImageView
                android:id="@+id/btn_recruiter_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_on_dark_70" />
        </LinearLayout>

        <!-- Avatar + identity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar circle -->
            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_border"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/tv_recruiter_avatar_initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R"
                    android:textSize="24sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_recruiter_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recruiter Name"
                    android:textSize="20sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/text_on_dark" />

                <TextView
                    android:id="@+id/tv_recruiter_role_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECRUITER"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/primary_light"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_recruiter_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_on_dark_60"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_edit_recruiter_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/primary_light"
                android:background="@drawable/bg_chip_unselected"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Total Jobs -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card_white"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_stat_total_jobs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Jobs"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Active Jobs -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card_white"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp">

                    <TextView
                        android:id="@+id/tv_stat_active_jobs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/success" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Jobs"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Total Applicants -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card_white"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginLeft="6dp">

                    <TextView
                        android:id="@+id/tv_stat_total_applicants"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/teal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Applicants"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Actions card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="16dp">

                <!-- Post New Job -->
                <LinearLayout
                    android:id="@+id/btn_recruiter_post_job"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_primary"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_briefcase"
                            android:contentDescription="Post job"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Post New Job"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/text_primary" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Navigate"
                        app:tint="@color/text_tertiary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="66dp"
                    android:background="@color/divider" />

                <!-- My Posted Jobs -->
                <LinearLayout
                    android:id="@+id/btn_recruiter_my_jobs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_primary"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chart"
                            android:contentDescription="My jobs"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Posted Jobs"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/text_primary" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Navigate"
                        app:tint="@color/text_tertiary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="66dp"
                    android:background="@color/divider" />

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/btn_recruiter_settings_action"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_primary"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_settings"
                            android:contentDescription="Settings"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Settings"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/text_primary" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Navigate"
                        app:tint="@color/text_tertiary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white">

                <LinearLayout
                    android:id="@+id/btn_recruiter_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/bg_tag_error"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_logout"
                            android:contentDescription="Logout"
                            app:tint="@color/error" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Log Out"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/error" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Navigate"
                        app:tint="@color/error" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
