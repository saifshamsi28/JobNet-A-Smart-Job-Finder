<?xml version="1.0" encoding="utf-8"?>
<!--
  Notification screen — premium two-mode layout.
  Header: back button, bold title, segmented mode badge, subtitle.
  Body: RecyclerView (items or skeletons) or empty state.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginTop="@dimen/page_margin"
    android:background="@color/bg_app">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="4dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <!-- Top row: back + title + mode badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btn_back_notifications"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="9dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:background="@drawable/bg_chip_unselected"
                android:clickable="true"
                android:focusable="true" />

            <!-- Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/notifications"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01" />

            <!-- Mode badge (seeker / recruiter) -->
            <TextView
                android:id="@+id/tv_notifications_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_chip_selected"
                android:text="Seeker"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Subtitle row -->
        <TextView
            android:id="@+id/tv_notifications_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="50dp"
            android:text="@string/notifications_subtitle_seeker"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/btn_notifications_mark_read"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="@string/notifications_mark_all_read"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_notifications_clear_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notifications_clear_all"
                android:textColor="@color/error"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Content ────────────────────────────────────────────────────────── -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_notifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        android:visibility="visible" />

    <!-- ── Empty state ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_notifications_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:visibility="gone">

        <!-- Illustration circle -->
        <LinearLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:gravity="center"
            android:background="@drawable/bg_empty_circle">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="No notifications"
                app:tint="@color/primary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_notifications_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/notifications_empty_title"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_notifications_empty_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/notifications_empty_seeker"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.45" />
    </LinearLayout>

</LinearLayout>
