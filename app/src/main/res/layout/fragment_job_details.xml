<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- Collapsing Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@color/bg_screen"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bg_screen"
            app:titleEnabled="false">

            <!-- Hero Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:layout_collapseMode="parallax">

                <!-- Blue gradient hero -->
                <LinearLayout
                    android:id="@+id/hero_content"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_gradient_primary"
                    android:paddingTop="80dp"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="24dp">

                    <!-- Company Logo Circle -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_border"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:id="@+id/iv_detail_logo"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_briefcase"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UI/UX Designer"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_detail_company"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google Inc."
                        android:textColor="@color/text_on_dark_70"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Top Action Bar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp">

                    <ImageView
                        android:id="@+id/iv_back"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/white" />

                    <View android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!--                    <ImageView-->
                    <!--                        android:id="@+id/iv_detail_bookmark"-->
                    <!--                        android:layout_width="40dp"-->
                    <!--                        android:layout_height="40dp"-->
                    <!--                        android:padding="8dp"-->
                    <!--                        android:src="@drawable/ic_bookmark"-->
                    <!--                        app:tint="@color/white"-->
                    <!--                        android:layout_marginEnd="4dp" />-->

                    <ImageView
                        android:id="@+id/iv_share"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_share"
                        app:tint="@color/white" />
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/details_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- Stats Row -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="18dp">

                    <!-- Salary -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_dollar"
                            app:tint="@color/primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tv_detail_salary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$120k/yr"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salary"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp"
                        android:background="@color/border" />

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tv_detail_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New York"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp"
                        android:background="@color/border" />

                    <!-- Type -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_briefcase"
                            app:tint="@color/primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tv_detail_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Time"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Job Type"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tv_application_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/application_status_none"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_semibold" />

                <TextView
                    android:id="@+id/btn_view_timeline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="@string/timeline_view_progress"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_semibold"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_withdraw_application_inline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timeline_withdraw_action"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_semibold"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Job Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Job Description"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We are looking for a talented UI/UX Designer to create amazing user experiences. The ideal candidate should have an eye for clean and artful design, possess superior UI skills and be able to translate high-level requirements into interaction flows and artifacts.\n\nYou will work closely with our product and engineering teams to design and build world-class digital products used by millions of users."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6"
                android:fontFamily="@font/inter_regular"
                android:layout_marginBottom="24dp" />

            <!-- Requirements -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requirements"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="12dp" />

            <!-- Requirement Items -->
            <LinearLayout
                android:id="@+id/ll_requirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <!-- Items added programmatically -->
            </LinearLayout>

            <!-- Skills Tags -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skills Required"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="12dp" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/flex_skills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap"
                app:alignItems="flex_start"
                app:justifyContent="flex_start"
                android:layout_marginBottom="24dp" />

            <!-- Company Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About Company"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_primary"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_briefcase"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_company_name_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google Inc."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/inter_semibold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Technology • 10,000+ Employees"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_regular" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"
                            app:tint="@color/accent_yellow"
                            android:layout_marginEnd="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.8"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Apply Bar — elevated with bookmark + apply CTA -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:elevation="16dp">

        <!-- Top shadow divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- Save bookmark button -->
            <LinearLayout
                android:id="@+id/btn_save_detail"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_detail_bookmark"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_bookmark"
                    android:contentDescription="Save job"
                    app:tint="@color/primary" />
            </LinearLayout>

            <!-- Apply Now button -->
            <LinearLayout
                android:id="@+id/btn_apply_now"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_button_primary"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_apply_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="Apply"
                    android:layout_marginEnd="8dp"
                    app:tint="@color/white" />

                <ProgressBar
                    android:id="@+id/progress_apply"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_apply_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/apply_now_label"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_semibold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
