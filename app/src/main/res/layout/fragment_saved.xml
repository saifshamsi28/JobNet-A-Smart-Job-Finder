<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:background="@color/bg_screen">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved Jobs"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_saved_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 jobs saved"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular" />
    </LinearLayout>

    <!-- Tabs Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tab_all"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="All Saved"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_chip_selected"
            android:textColor="@color/white"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tab_applied"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Applied"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_chip_unselected"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_saved_jobs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false" />
</LinearLayout>
