<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_dark"
            android:paddingLeft="@dimen/page_margin"
            android:paddingRight="@dimen/page_margin"
            android:paddingTop="52dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btn_back_recruiter_jobs"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back"
                    app:tint="@color/text_on_dark"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="All Posted Jobs"
                    android:textColor="@color/text_on_dark"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Search and filter all your openings"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/surface"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginLeft="@dimen/page_margin"
            android:layout_marginRight="@dimen/page_margin"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                app:tint="@color/text_tertiary" />

            <EditText
                android:id="@+id/et_recruiter_jobs_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@android:color/transparent"
                android:hint="Search by role, company, location"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="14sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="@dimen/page_margin"
            android:paddingRight="@dimen/page_margin"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/row_recruiter_jobs_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_recruiter_jobs_all"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_selected"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="All (0)"
                    android:textColor="@color/text_chip_selected"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_recruiter_jobs_active"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="Active (0)"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_recruiter_jobs_closed"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="Closed (0)"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_recruiter_jobs_draft"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="Draft (0)"
                    android:textColor="@color/text_chip"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <ProgressBar
            android:id="@+id/progress_recruiter_all_jobs"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:indeterminateTint="@color/primary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_recruiter_jobs_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_briefcase"
                android:contentDescription="No jobs"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/tv_recruiter_jobs_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No matching jobs"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_recruiter_jobs_empty_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Try changing your search or status filters."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_recruiter_all_jobs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingLeft="@dimen/page_margin"
            android:paddingRight="@dimen/page_margin"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
