<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium notification card.
  Structure: icon bubble | content (title, message, chips row) | chevron
  Unread dot sits top-right of the icon bubble.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface"
    app:cardUseCompatPadding="false"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Icon bubble with optional unread dot -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp">

            <!-- Circular icon background -->
            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:background="@drawable/bg_icon_surface">

                <ImageView
                    android:id="@+id/iv_notification_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_briefcase"
                    android:contentDescription="Notification type"
                    app:tint="@color/primary" />
            </LinearLayout>

            <!-- Unread dot — top-right of bubble -->
            <View
                android:id="@+id/view_unread_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_unread_dot"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_notification_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Application received" />

            <TextView
                android:id="@+id/tv_notification_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.35"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Your application for Frontend Engineer at Acme is now under review." />

            <!-- Status chip + timestamp row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="9dp">

                <TextView
                    android:id="@+id/tv_notification_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_tag_primary"
                    android:text="APPLIED"
                    android:textColor="@color/status_applied_text"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_dot_tertiary" />

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Time"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tv_notification_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Just now"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_right"
            android:contentDescription="Open"
            app:tint="@color/text_tertiary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
