<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="horizontal"
    android:minHeight="84dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_gravity="center_horizontal">

            <View
                android:id="@+id/view_timeline_step_ring"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_timeline_pulse_ring"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_timeline_step_icon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/bg_timeline_icon_pending">

                <ImageView
                    android:id="@+id/iv_timeline_step_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Step"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
        </FrameLayout>

        <View
            android:id="@+id/view_timeline_step_line"
            android:layout_width="2dp"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:background="@color/border" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tv_timeline_step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Applied"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_timeline_step_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Pending"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
