<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <LinearLayout
        android:id="@+id/category_jobs_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_primary"
        android:paddingLeft="14dp"
        android:paddingTop="12dp"
        android:paddingRight="20dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/btn_back_category_jobs"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                android:tint="@color/white"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Category Jobs"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/inter_semibold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_category_jobs_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Engineering"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="@font/inter_bold" />

        <TextView
            android:id="@+id/tv_category_jobs_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Roles tailored to your selected category"
            android:textColor="@color/text_on_dark_80"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="154dp"
        android:orientation="vertical"
        android:background="@color/bg_screen">

        <TextView
            android:id="@+id/tv_category_jobs_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="20dp"
            android:paddingTop="14dp"
            android:paddingRight="20dp"
            android:paddingBottom="8dp"
            android:text="0 jobs found"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_category_jobs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="90dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/layout_category_jobs_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No jobs in this category yet"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/inter_semibold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Try another category or check back later"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
