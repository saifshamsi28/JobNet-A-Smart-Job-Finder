<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Avatar circle -->
        <LinearLayout
            android:id="@+id/iv_applicant_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_primary"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tv_applicant_initial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textSize="18sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- Name + applied date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_applicant_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applicant Name"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_applicant_applied_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applied recently"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Status chip -->
        <TextView
            android:id="@+id/tv_applicant_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPLIED"
            android:textSize="11sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/status_applied_text"
            android:background="@drawable/bg_tag_primary"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Action row: status update buttons -->
    <LinearLayout
        android:id="@+id/row_applicant_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_shortlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shortlist"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/status_shortlisted_text"
            android:background="@drawable/bg_tag_warning"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_reject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reject"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/status_rejected_text"
            android:background="@drawable/bg_tag_error"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
