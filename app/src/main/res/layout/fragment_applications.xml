<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="52dp"
                android:paddingBottom="36dp">

                <!-- Back + Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/btn_back_applications"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_back"
                        android:contentDescription="Back"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="@color/text_on_dark" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/my_applications"
                        android:textColor="@color/text_on_dark"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track your job applications and their status"
                    android:textColor="@color/text_on_dark_70"
                    android:textSize="@dimen/text_base"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- STATUS FILTER CHIPS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="@dimen/space_16"
                android:paddingBottom="@dimen/space_8"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:text="All"
                        android:gravity="center"
                        android:textColor="@color/text_chip_selected"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:text="Applied"
                        android:gravity="center"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:text="Reviewed"
                        android:gravity="center"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:text="Shortlisted"
                        android:gravity="center"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="8dp"
                        android:text="Offered"
                        android:gravity="center"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="Rejected"
                        android:gravity="center"
                        android:textColor="@color/text_chip"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Count display -->
            <TextView
                android:id="@+id/tv_applications_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:paddingTop="@dimen/space_8"
                android:paddingBottom="@dimen/space_8"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                android:fontFamily="sans-serif"
                android:visibility="visible" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/applications_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/tv_no_applications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp"
                android:paddingBottom="40dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_primary"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_briefcase"
                        android:contentDescription="No applications"
                        app:tint="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No applications yet"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_applications"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_base"
                    android:gravity="center"
                    android:paddingHorizontal="32dp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Applications list -->
            <LinearLayout
                android:id="@+id/container_applications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingLeft="@dimen/page_margin"
                android:paddingRight="@dimen/page_margin"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
