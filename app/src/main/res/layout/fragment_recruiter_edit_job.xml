<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/edit_job_root"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar_edit_job"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingLeft="8dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back_edit_job"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:text="Edit Job"
            android:textSize="17sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/text_primary" />

        <!-- Close/Reopen toggle -->
        <TextView
            android:id="@+id/btn_toggle_job_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close Job"
            android:textSize="13sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/error"
            android:background="@drawable/bg_tag_error"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/edit_job_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Job Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Job Title"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Senior Android Engineer"
                    android:inputType="textCapWords|text"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Company -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Company"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_company"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your company name"
                    android:inputType="textCapWords|text"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="City, Remote, Hybrid…"
                    android:inputType="textCapWords|text"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Salary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_salary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. $80k – $100k"
                    android:inputType="text"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Openings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Openings"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_openings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 2"
                    android:inputType="number"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Job Type row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Job Type"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semibold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/input_edit_job_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Time"
                            android:inputType="none"
                            android:focusable="false"
                            android:clickable="true"
                            android:fontFamily="@font/inter_regular"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Work Mode"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semibold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/input_edit_work_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="On-site"
                            android:inputType="none"
                            android:focusable="false"
                            android:clickable="true"
                            android:fontFamily="@font/inter_regular"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Short Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short Description"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_short_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Brief summary shown in listings"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="2"
                    android:gravity="top"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Full Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Description"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit_full_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full role details, responsibilities, requirements…"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="5"
                    android:gravity="top"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/edit_job_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="6dp"
        android:paddingLeft="20dp"
        android:paddingTop="10dp"
        android:paddingRight="20dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_job_edits"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Changes"
            android:textSize="16sp"
            android:fontFamily="@font/inter_semibold"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp" />

        <ProgressBar
            android:id="@+id/progress_edit_job"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
