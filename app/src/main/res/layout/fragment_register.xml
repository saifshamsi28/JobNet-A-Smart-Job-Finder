<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Dark gradient hero header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingTop="64dp"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="52dp">

                <!-- Logo mark -->
                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="@color/overlay_white_13"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_briefcase"
                        android:contentDescription="JobNet"
                        app:tint="@color/text_on_dark" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_welcome"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.06" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/register_header"
                    android:textColor="@color/text_on_dark"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/register_subtitle"
                    android:textColor="@color/text_on_dark_70"
                    android:textSize="@dimen/text_base"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Floating card form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-28dp"
                android:background="@drawable/bg_card_white"
                android:layout_marginLeft="@dimen/page_margin"
                android:layout_marginRight="@dimen/page_margin"
                android:padding="24dp">

                <!-- ROLE SELECTION — Card-based toggle for premium feel -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_role"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Job Seeker option -->
                    <LinearLayout
                        android:id="@+id/card_role_seeker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_role_card_selected"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_person"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Job Seeker"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/role_job_seeker"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Find great jobs"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/text_xs"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Recruiter option -->
                    <LinearLayout
                        android:id="@+id/card_role_recruiter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp"
                        android:background="@drawable/bg_role_card_unselected"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_users"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Recruiter"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/role_recruiter"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Post &amp; hire talent"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/text_xs"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Hidden RadioGroup for wiring (keeps existing Fragment code working) -->
                <RadioGroup
                    android:id="@+id/group_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_job_seeker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/role_job_seeker"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/radio_recruiter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:text="@string/role_recruiter"
                        android:textColor="@color/text_primary" />
                </RadioGroup>

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_name_hint"
                    android:inputType="textCapWords|textPersonName"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/register_username"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_username"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_username_hint"
                    android:inputType="text"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/register_email"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_email_hint"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/login_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_password_register"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_auth_input"
                        android:hint="@string/login_password_hint"
                        android:inputType="textPassword"
                        android:paddingLeft="16dp"
                        android:paddingRight="52dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                    <TextView
                        android:id="@+id/btn_toggle_register_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"
                        android:text="@string/show_password"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:contentDescription="@string/toggle_password"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <!-- Confirm password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/register_confirm_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_auth_input"
                        android:hint="@string/register_confirm_password_hint"
                        android:inputType="textPassword"
                        android:paddingLeft="16dp"
                        android:paddingRight="52dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                    <TextView
                        android:id="@+id/btn_toggle_register_confirm_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"
                        android:text="@string/show_password"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:contentDescription="@string/toggle_password"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <!-- Register button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/register_title_cta"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_lg"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="14dp" />

                <ProgressBar
                    android:id="@+id/register_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />

                <!-- Sign in prompt -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_have_account"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:id="@+id/btn_go_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/sign_in"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_sm"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
