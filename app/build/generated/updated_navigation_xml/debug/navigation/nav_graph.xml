<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/nav_graph"
app:startDestination="@id/homeFragment" >
<fragment
    android:id="@+id/loginFragment"
    android:name="com.jobnet.app.ui.auth.LoginFragment"
    android:label="Login" >

    <action
        android:id="@+id/action_loginFragment_to_registerFragment"
        app:destination="@id/registerFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    <action
        android:id="@+id/action_loginFragment_to_homeFragment"
        app:destination="@id/homeFragment"
        app:popUpTo="@id/loginFragment"
        app:popUpToInclusive="true" />
    <action
        android:id="@+id/action_loginFragment_to_recruiterDashboardFragment"
        app:destination="@id/recruiterDashboardFragment"
        app:popUpTo="@id/loginFragment"
        app:popUpToInclusive="true" />

</fragment>
<fragment
    android:id="@+id/registerFragment"
    android:name="com.jobnet.app.ui.auth.RegisterFragment"
    android:label="Register" >

    <action
        android:id="@+id/action_registerFragment_to_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/registerFragment"
        app:popUpToInclusive="true" />

</fragment>
<fragment
    android:id="@+id/homeFragment"
    android:name="com.jobnet.app.ui.home.HomeFragment"
    android:label="Home" >

    <action
        android:id="@+id/action_home_to_jobDetails"
        app:destination="@id/jobDetailsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

</fragment>
<fragment
    android:id="@+id/searchFragment"
    android:name="com.jobnet.app.ui.search.SearchFragment"
    android:label="Search" >

    <action
        android:id="@+id/action_search_to_jobDetails"
        app:destination="@id/jobDetailsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

</fragment>
<fragment
    android:id="@+id/savedFragment"
    android:name="com.jobnet.app.ui.saved.SavedJobsFragment"
    android:label="Saved" >

    <action
        android:id="@+id/action_saved_to_jobDetails"
        app:destination="@id/jobDetailsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

</fragment>
<fragment
    android:id="@+id/profileFragment"
    android:name="com.jobnet.app.ui.profile.ProfileFragment"
    android:label="Profile" >

    <action
        android:id="@+id/action_profileFragment_to_applicationsFragment"
        app:destination="@id/applicationsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    <action
        android:id="@+id/action_profileFragment_to_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/homeFragment"
        app:popUpToInclusive="true" />

</fragment>
<fragment
    android:id="@+id/applicationsFragment"
    android:name="com.jobnet.app.ui.applications.ApplicationsFragment"
    android:label="My Applications" >

    <action
        android:id="@+id/action_applicationsFragment_to_jobDetailsFragment"
        app:destination="@id/jobDetailsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

</fragment>
<fragment
    android:id="@+id/jobDetailsFragment"
    android:name="com.jobnet.app.ui.jobdetails.JobDetailsFragment"
    android:label="Job Detail" />
<fragment
    android:id="@+id/recruiterDashboardFragment"
    android:name="com.jobnet.app.ui.recruiter.RecruiterDashboardFragment"
    android:label="Recruiter Dashboard" >

    <action
        android:id="@+id/action_recruiterDashboardFragment_to_recruiterPostJobFragment"
        app:destination="@id/recruiterPostJobFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    <action
        android:id="@+id/action_recruiterDashboardFragment_to_jobDetailsFragment"
        app:destination="@id/jobDetailsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

</fragment>
<fragment
    android:id="@+id/recruiterPostJobFragment"
    android:name="com.jobnet.app.ui.recruiter.RecruiterPostJobFragment"
    android:label="Post Job" />
</navigation>