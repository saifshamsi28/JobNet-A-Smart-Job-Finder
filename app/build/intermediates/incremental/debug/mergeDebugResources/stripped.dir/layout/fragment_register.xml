<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:orientation="vertical"
                android:paddingLeft="@dimen/page_margin"
                android:paddingTop="56dp"
                android:paddingRight="@dimen/page_margin"
                android:paddingBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_welcome"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/register_header"
                    android:textColor="@color/text_on_dark"
                    android:textSize="30sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/register_subtitle"
                    android:textColor="@color/text_on_dark_70"
                    android:textSize="@dimen/text_base" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:background="@drawable/bg_card_white"
                android:layout_marginLeft="@dimen/page_margin"
                android:layout_marginRight="@dimen/page_margin"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_name_hint"
                    android:inputType="textPersonName"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/register_username"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_username"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_username_hint"
                    android:inputType="text"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/register_email"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_email_hint"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/login_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_password_register"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/register_confirm_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_auth_input"
                    android:hint="@string/register_confirm_password_hint"
                    android:inputType="textPassword"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/register_role"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <RadioGroup
                    android:id="@+id/group_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_job_seeker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/role_job_seeker"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/radio_recruiter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:text="@string/role_recruiter"
                        android:textColor="@color/text_primary" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/register_title_cta"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_lg"
                    app:cornerRadius="14dp" />

                <ProgressBar
                    android:id="@+id/register_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:text="@string/register_have_account"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/btn_go_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:text="@string/sign_in"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_md"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
