<?xml version="1.0" encoding="utf-8"?>
<!-- Featured job card - gradient background, dark text -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/featured_card_width"
    android:layout_height="@dimen/featured_card_height"
    android:background="@drawable/bg_featured_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Decorative circle blob top-right -->
    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-30dp"
        android:layout_marginEnd="-30dp"
        android:background="@color/overlay_white_13"
        android:backgroundTint="@color/overlay_white_13" />

    <!-- Decorative circle blob bottom-left -->
    <View
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-20dp"
        android:layout_marginStart="-20dp"
        android:background="@color/overlay_white_08"
        android:backgroundTint="@color/overlay_white_08" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Top row: Logo + Bookmark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Company logo container -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@color/overlay_white_19"
                android:backgroundTint="@color/overlay_white_19">
                <ImageView
                    android:id="@+id/iv_featured_logo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_briefcase"
                    android:tint="@color/text_on_dark"
                    android:contentDescription="Company logo" />
            </FrameLayout>

            <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" />

            <!-- Bookmark icon -->
            <ImageView
                android:id="@+id/iv_featured_bookmark"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_bookmark"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Save" />

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="0dp" />

        <!-- Bottom: Job info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_featured_company"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Google"
                android:textColor="@color/text_on_dark_73"
                android:textSize="@dimen/text_sm"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/tv_featured_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Senior Product Designer"
                android:textColor="@color/text_on_dark"
                android:textSize="@dimen/text_xl"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2" />

            <!-- Tags -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_featured_salary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="$120k/yr"
                    android:textColor="@color/text_on_dark"
                    android:textSize="@dimen/text_xs"
                    android:fontFamily="sans-serif-medium"
                    android:background="@color/overlay_white_19"
                    android:backgroundTint="@color/overlay_white_19"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />

                <TextView
                    android:id="@+id/tv_featured_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remote"
                    android:textColor="@color/text_on_dark"
                    android:textSize="@dimen/text_xs"
                    android:fontFamily="sans-serif-medium"
                    android:background="@color/overlay_white_19"
                    android:backgroundTint="@color/overlay_white_19"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
