<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item
        android:left="4dp"
        android:top="6dp"
        android:right="4dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#204F46E5" />
            <corners android:radius="@dimen/radius_xl" />
        </shape>
    </item>
    <!-- Main gradient card -->
    <item
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4F46E5"
                android:centerColor="#6D28D9"
                android:endColor="#7C3AED"
                android:angle="135" />
            <corners android:radius="@dimen/radius_xl" />
        </shape>
    </item>
</layer-list>
